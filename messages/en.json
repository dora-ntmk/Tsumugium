{
  "_footer": {
    "auto_translation": "This message was automatically translated by AI and may be inaccurate."
  },
  "commands": {
    "join": {
      "description": "Connect to a voice channel.",
      "args": {
        "change_channel": "Set to True to apply TextTarget and VoiceTarget to server settings"
      }
    },
    "leave": {
      "description": "Disconnect from the voice channel."
    },
    "clear": {
      "description": "Clear all items in the TTS queue."
    },
    "dict": {
      "_group": "Manage the TTS dictionary",
      "add": {
        "description": "Add a word reading to the dictionary",
        "args": {
          "word": "Word to add",
          "read": "Reading (up to 50 characters)"
        }
      },
      "del": {
        "description": "Remove a word reading from the dictionary",
        "args": {
          "word": "Word to remove"
        }
      },
      "view": {
        "description": "View the dictionary contents",
        "args": {
          "ephemeral": "Set to True to show only to yourself",
          "search": "Search string (partial match)"
        }
      }
    },
    "setting": {
      "_group": "Manage server settings",
      "view": {
        "description": "Display current settings"
      },
      "text_target": {
        "description": "Set the text channel to read aloud (defaults to current channel)",
        "args": {
          "channel": "Text channel to set (defaults to current channel)"
        }
      },
      "text_target_reset": {
        "description": "Reset TextTarget to unset"
      },
      "voice_target": {
        "description": "Set the auto-join VC (defaults to current VC)",
        "args": {
          "channel": "Voice channel to set (defaults to current VC)"
        }
      },
      "voice_target_reset": {
        "description": "Reset VoiceTarget to unset"
      },
      "speaker": {
        "description": "Set the VOICEVOX speaker",
        "args": {
          "speaker": "VOICEVOX speaker name to use"
        }
      },
      "volume": {
        "description": "Set the volume (0-100)",
        "args": {
          "volume": "Volume (0-100)"
        }
      },
      "speed": {
        "description": "Set the TTS speed (50-200)",
        "args": {
          "speed": "Speed (50-200, 100 is normal)"
        }
      },
      "max_char": {
        "description": "Set the max characters to read aloud (30-200, 0 resets to default (50))",
        "args": {
          "chars": "Max characters to read aloud (30-200, 0 resets to default (50))"
        }
      },
      "auto_join": {
        "description": "Set whether to auto-join when someone enters a VC",
        "args": {
          "enabled": "Whether to enable"
        }
      },
      "access_notice": {
        "description": "Set whether to announce VC join/leave via TTS",
        "args": {
          "enabled": "Whether to enable"
        }
      },
      "language": {
        "description": "Set the bot response language",
        "args": {
          "language": "Language to use"
        }
      }
    }
  },
  "clear": {
    "clearing": {
      "title": "Clearing",
      "description": "Clearing the queue, please wait...",
      "color": "blue"
    },
    "success": {
      "title": "Queue Cleared",
      "description": "Cancelled all TTS item(s)",
      "color": "green"
    }
  },
  "join": {
    "notice_text": "{display_name} has joined",
    "auto": {
      "title": "Auto Join",
      "description": "Automatically connected to the voice channel",
      "color": "blue",
      "fields": [
        {
          "name": "Connection Info",
          "value": "VC: {vc}  Text: {text}",
          "inline": false
        }
      ]
    },
    "success": {
      "title": "Connected",
      "description": "Connected to the voice channel",
      "color": "green"
    },
    "success_temp": {
      "title": "Connected",
      "description": "Connected to the voice channel.\nMessages from {text} will also be read aloud for this session.",
      "color": "green",
      "fields": [
        {
          "name": "Connection Info",
          "value": "VC: {vc}  Text: {text}",
          "inline": false
        }
      ]
    },
    "success_change_channel": {
      "title": "Connected",
      "description": "Connected to the voice channel.\nTextTarget set to {text}, VoiceTarget set to {voice}.",
      "color": "green",
      "fields": [
        {
          "name": "Connection Info",
          "value": "VC: {vc}  Text: {text}",
          "inline": false
        }
      ]
    },
    "failure_change_channel": {
      "title": "Settings Failed",
      "description": "Failed to save channel settings",
      "color": "red"
    },
    "failure": {
      "title": "Connection Failed",
      "description": "Failed to connect to the voice channel",
      "color": "red"
    },
    "no_permission": {
      "title": "Permission Error",
      "description": "{issues}",
      "color": "red"
    },
    "no_permission_vc": "No permission to connect to {channel}.",
    "no_permission_text": "No permission to view {channel}.",
    "no_permission_text_dm": "Auto-join failed because the bot does not have permission to access the text channel you connected to."
  },
  "leave": {
    "notice_text": "{display_name} has left",
    "success": {
      "title": "Disconnected",
      "description": "Disconnected from the voice channel",
      "color": "green"
    },
    "failure": {
      "title": "Disconnect Failed",
      "description": "Failed to disconnect from the voice channel",
      "color": "red"
    },
    "auto": {
      "title": "Auto Leave",
      "description": "Left the voice channel because it became empty",
      "color": "blue"
    },
    "forced": {
      "title": "Disconnected",
      "description": "Disconnected from the voice channel",
      "color": "red"
    }
  },
  "dict": {
    "add": {
      "success": {
        "title": "Word Added Successfully",
        "description": "The word reading has been added to the dictionary",
        "color": "green",
        "fields": [{"name": "Entry", "value": "`{word}` → `{read}`", "inline": false}]
      },
      "overwrite": {
        "title": "Word Overwritten Successfully",
        "description": "The word reading has been overwritten in the dictionary",
        "color": "green",
        "fields": [{"name": "Entry", "value": "`{word}` → `{read}`", "inline": false}]
      },
      "too_long": {
        "title": "Reading Too Long",
        "description": "`{read}` exceeds 50 characters and cannot be added.\nPlease keep the reading within 50 characters.",
        "color": "red"
      },
      "failure": {
        "title": "Failed to Add Word",
        "description": "Could not add the word to the dictionary",
        "color": "red"
      }
    },
    "del": {
      "success": {
        "title": "Word Removed Successfully",
        "description": "The word and its reading have been removed from the dictionary",
        "color": "green",
        "fields": [{"name": "Removed Entry", "value": "`{word}` → `{read}`", "inline": false}]
      },
      "not_found": {
        "title": "Word Not Found",
        "description": "`{word}` was not found in the dictionary. Please check and try again.",
        "color": "red"
      },
      "failure": {
        "title": "Failed to Remove Word",
        "description": "Could not remove the word from the dictionary",
        "color": "red"
      }
    },
    "view": {
      "title": "Dictionary",
      "description": "",
      "color": "blue",
      "empty": "No words are registered in the dictionary",
      "more": "({count} more)",
      "page": "Page {page} / {total}",
      "prefix": "",
      "header": "Word  →  Reading",
      "section_normal": "Normal",
      "section_priority": "Priority",
      "not_found": {
        "title": "Not Found",
        "description": "No entries found for \"{word}\"",
        "color": "red"
      }
    },
    "error": {
      "no_permission": {
        "title": "Permission Error",
        "description": "Server management permission is required",
        "color": "red"
      }
    }
  },
  "error": {
    "os_error": {
      "title": "System Error",
      "description": "Failed to save settings",
      "color": "red"
    }
  },
